{
  "manifest_version": 3,
  "name": "Benchmark Recorder (WXT)",
  "description": "Record tab video, store in IndexedDB (max 5MB), React+Tailwind",
  "version": "0.0.1",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "tabCapture",
    "offscreen",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content-ui/index.html"
      ]
    },
    {
      "resources": [
        "content-scripts/content.css"
      ],
      "use_dynamic_url": true,
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "网页录制",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html"
  },
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3000; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3000; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}