{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "types": ["wxt/client-types", "chrome", "node"],
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["entrypoints", "components", "utils", "wxt.config.ts", "env.d.ts"],
  "exclude": [".output", ".wxt", "node_modules"]
}
